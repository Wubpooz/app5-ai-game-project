// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── better-auth required tables ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Game ratings
  rating        Int       @default(1200)
  gamesPlayed   Int       @default(0)
  wins          Int       @default(0)
  losses        Int       @default(0)
  draws         Int       @default(0)

  // Relations
  sessions      Session[]
  accounts      Account[]
  whiteGames    Game[]    @relation("WhitePlayer")
  blackGames    Game[]    @relation("BlackPlayer")
  ratingHistory Rating[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String  @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Game tables ──────────────────────────────────────────────────────────────

model Game {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Players (null = bot / guest)
  whitePlayerId    String?
  blackPlayerId    String?
  whitePlayerName  String   @default("White")
  blackPlayerName  String   @default("Black")
  whiteIsBot       Boolean  @default(false)
  blackIsBot       Boolean  @default(false)
  whiteBotLevel    Int?
  blackBotLevel    Int?

  // Position & moves
  whitePlacement   String   // ESN placement: "A1/B1/C1/D1/E1/F1"
  blackPlacement   String
  moves            String   // Comma-separated move list in internal format
  initialEPN       String?  // Starting position if not standard

  // Time control
  timeControlSecs  Int?     // seconds per side, null = unlimited
  incrementSecs    Int      @default(0)

  // Result
  result           String?  // "white" | "black" | "draw" | null (in progress)
  terminationKind  String?  // "unicorn_captured" | "timeout" | "resignation" | "agreement"

  // Ratings at time of game
  whiteRatingBefore Int?
  blackRatingBefore Int?
  whiteRatingAfter  Int?
  blackRatingAfter  Int?

  // Relations
  whitePlayer      User?    @relation("WhitePlayer", fields: [whitePlayerId], references: [id])
  blackPlayer      User?    @relation("BlackPlayer", fields: [blackPlayerId], references: [id])
  ratings          Rating[]
}

model Rating {
  id          String   @id @default(cuid())
  userId      String
  gameId      String
  ratingBefore Int
  ratingAfter  Int
  ratingDelta  Int
  createdAt   DateTime @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game  Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
}
